// Windows resource script: embeds the application icon into Hazor.exe.
// The first icon in a .rc (lowest ID) becomes the executable's shell icon.
// Compiled only on Windows (see CMakeLists.txt); the .ico is generated by
// tools/generate_app_icon_ico.py from src/resources/icons/app-icon.png.
IDI_ICON1 ICON "icons/app-icon.ico"
