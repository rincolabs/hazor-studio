# Vendored third-party deps: track the skeleton folders (via .gitkeep), ignore
# all downloaded contents. The directory re-include lets nested .gitkeep survive.
/3rdparty/**
!/3rdparty/**/
!/3rdparty/**/.gitkeep

# Shape SVGs are generated at build time (Material Design Icons): track the
# folder (empty), ignore its contents.
/src/resources/shapes/*
!/src/resources/shapes/.gitkeep
CLAUDE.md